.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  color: #9aa4b5;
  font-size: 24rpx;
}

.load-more.error {
  color: #2f7bff;
}

.spinner {
  width: 26rpx;
  height: 26rpx;
  margin-right: 12rpx;
  border: 3rpx solid #dbe7ff;
  border-top-color: #2f7bff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
