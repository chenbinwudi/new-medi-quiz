.error-card {
  display: flex;
  align-items: center;
  min-height: 132rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 181, 71, 0.28);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffaf1, #fff);
  box-shadow: 0 12rpx 30rpx rgba(180, 117, 31, 0.07);
  box-sizing: border-box;
}

.error-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  background: #fff2dc;
}

.error-img {
  width: 48rpx;
  height: 48rpx;
}

.error-main {
  flex: 1;
  min-width: 0;
}

.error-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
}

.error-desc {
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
}

.retry-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 62rpx;
  margin-left: 18rpx;
  border: 0;
  border-radius: 999rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: normal;
}

.retry-btn::after {
  border: 0;
}
