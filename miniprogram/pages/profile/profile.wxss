.profile-card,
.member-card,
.shortcut-row,
.menu-row,
.menu-left {
  display: flex;
  align-items: center;
}

.profile-card {
  min-height: 132rpx;
  padding: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  margin-right: 24rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #eaf2ff, #d8e7ff);
  color: #2f7bff;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.name {
  margin-bottom: 8rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 800;
}

.login-btn {
  width: 132rpx;
  height: 64rpx;
  border: 0;
  border-radius: 999rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 24rpx;
  line-height: 64rpx;
}

.login-btn::after {
  border: 0;
}

.member-card {
  justify-content: space-between;
  margin: 28rpx 0;
  padding: 30rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #151923, #343b4e);
  color: #fff;
  box-shadow: 0 18rpx 36rpx rgba(21, 25, 35, 0.16);
}

.member-title {
  font-size: 30rpx;
  font-weight: 800;
}

.member-sub {
  margin-top: 8rpx;
  color: #cfd6e6;
  font-size: 23rpx;
}

.member-btn {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #ffe0a8;
  color: #4d3414;
  font-size: 24rpx;
  font-weight: 700;
}

.shortcut-row {
  justify-content: space-between;
  padding: 26rpx 18rpx;
}

.shortcut {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
}

.shortcut-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  height: 70rpx;
  margin: 0 auto 12rpx;
  border-radius: 20rpx;
  background: #eef5ff;
}

.shortcut-icon.red {
  background: #fff0f0;
}

.shortcut-icon.amber {
  background: #fff7df;
}

.shortcut-icon.teal {
  background: #e8fbf7;
}

.shortcut-icon.green {
  background: #eaf9f0;
}

.shortcut-img {
  width: 42rpx;
  height: 42rpx;
}

.shortcut-label {
  color: #263247;
  white-space: nowrap;
}

.menu-card {
  margin-top: 28rpx;
  padding: 6rpx 28rpx;
}

.menu-row {
  justify-content: space-between;
  min-height: 94rpx;
  border-bottom: 1rpx solid #eef1f6;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-left {
  gap: 20rpx;
  color: #263247;
  font-size: 27rpx;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
}

.menu-arrow {
  color: #b5becc;
  font-size: 34rpx;
}
