<view class="page page-safe profile-page">
  <skeleton-card wx:if="{{loading}}" type="profile" />

  <block wx:else>
    <error-state
      wx:if="{{error}}"
      title="个人数据加载失败"
      desc="会员和学习信息暂时没有取到"
      bind:retry="reload"
    />

    <view class="profile-card soft-card">
      <view class="avatar">{{displayUser.avatarText}}</view>
      <view class="profile-main">
        <view class="name">{{displayUser.nickname}}</view>
        <view class="muted">ID: {{displayUser.openid}}</view>
      </view>
      <button class="login-btn" loading="{{syncing}}" disabled="{{syncing}}" bindtap="login">{{displayUser.buttonText}}</button>
    </view>

    <view class="member-card tap-card" hover-class="tap-card-active" hover-stay-time="80" bindtap="goMember">
      <view>
        <view class="member-title">会员中心</view>
        <view class="member-sub">开通会员，享尊贵权益</view>
      </view>
      <view class="member-btn">{{memberButtonText}}</view>
    </view>

    <view class="section">
      <view class="section-head">
        <text class="section-title">我的学习</text>
      </view>
      <view class="shortcut-row soft-card">
        <view
          wx:for="{{shortcuts}}"
          wx:key="label"
          class="shortcut tap-card"
          hover-class="tap-card-active"
          hover-stay-time="80"
          data-url="{{item.url}}"
          bindtap="go"
        >
          <view class="shortcut-icon {{item.tone}}">
            <image class="shortcut-img" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <view class="shortcut-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="menu-card card">
      <view
        wx:for="{{menus}}"
        wx:key="label"
        class="menu-row tap-card"
        hover-class="tap-card-active"
        hover-stay-time="80"
        data-name="{{item.label}}"
        bindtap="menuTap"
      >
        <view class="menu-left">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
          <text>{{item.label}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </block>
</view>
