.list-page {
  padding-bottom: 150rpx;
}

.centered {
  justify-content: center;
}

.summary {
  margin: 28rpx 0 14rpx;
  font-size: 24rpx;
}

.question-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
}

.tag {
  display: inline-block;
  margin-bottom: 14rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf2ff;
  color: #2f7bff;
  font-size: 22rpx;
  font-weight: 700;
}

.stem {
  margin-bottom: 14rpx;
  color: #172033;
  font-weight: 700;
  line-height: 1.62;
}

.meta {
  margin-bottom: 18rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.foot {
  color: #8a94a6;
  font-size: 24rpx;
}

.fixed-btn {
  position: fixed;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  left: 28rpx;
  height: 88rpx;
  border: 0;
  border-radius: 24rpx;
  background: #2f7bff;
  color: #fff;
  font-weight: 700;
  line-height: 88rpx;
  box-shadow: 0 14rpx 28rpx rgba(47, 123, 255, 0.22);
}

.fixed-btn::after {
  border: 0;
}
