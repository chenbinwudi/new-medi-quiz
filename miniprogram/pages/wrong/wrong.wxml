<view class="page page-safe list-page">
  <view class="top-bar centered">
    <view class="page-title">错题本</view>
  </view>
  <seg-tabs tabs="{{tabs}}" active="{{active}}" bind:change="onTabChange" />
  <view class="summary muted">{{listCountText}}</view>

  <empty-state wx:if="{{emptyVisible}}" title="暂无错题" desc="完成练习后会自动收集错题" actionText="去练习" bind:action="goPractice" icon="/assets/icons/wrong-book.svg" />

  <view wx:for="{{list}}" wx:key="questionId" class="question-card card">
    <view class="tag">{{item.typeLabel}}</view>
    <view class="stem">{{item.question.stem}}</view>
    <view class="meta">章节：{{item.chapterName}}</view>
    <view class="row-between foot">
      <text>错误次数：<text class="red">{{item.countText}}</text></text>
      <text class="muted">{{item.dateText}}</text>
    </view>
  </view>

  <button class="fixed-btn" bindtap="goPractice">错题重做</button>
</view>
