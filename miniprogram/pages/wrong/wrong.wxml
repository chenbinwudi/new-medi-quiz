<view class="page list-page">
  <view class="nav-title">错题本</view>
  <seg-tabs tabs="{{tabs}}" active="{{active}}" bind:change="onTabChange" />
  <view class="summary muted">共{{list.length}}题</view>

  <empty-state wx:if="{{!loading && !list.length}}" title="暂无错题" desc="完成练习后会自动收集错题" actionText="去练习" bind:action="goPractice" />

  <view wx:for="{{list}}" wx:key="questionId" class="question-card">
    <view class="tag">{{item.typeLabel}}</view>
    <view class="stem">{{item.question.stem}}</view>
    <view class="meta">章节：{{item.chapterName}}</view>
    <view class="row">
      <text>错误次数：<text class="red">{{item.wrongCount}}</text></text>
      <text class="muted">{{item.dateText}}</text>
    </view>
  </view>

  <button class="fixed-btn" bindtap="goPractice">错题重做</button>
</view>
