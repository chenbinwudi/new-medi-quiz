.practice-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 168rpx;
  box-sizing: border-box;
  background: #fff;
}

.practice-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 34rpx;
}

.title {
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.chapter-name {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.head-right {
  text-align: right;
}

.badge {
  display: inline-block;
  margin-bottom: 8rpx;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #eaf2ff;
  color: #2f7bff;
  font-size: 22rpx;
  font-weight: 700;
}

.question-card {
  padding-top: 8rpx;
}

.stem {
  margin-bottom: 30rpx;
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.75;
}

.option {
  display: flex;
  align-items: flex-start;
  margin-bottom: 22rpx;
  padding: 22rpx;
  border: 2rpx solid #e4eaf3;
  border-radius: 24rpx;
  background: #fff;
  box-sizing: border-box;
}

.option.selected {
  border-color: #2f7bff;
  background: #f1f6ff;
}

.option.correct {
  border-color: #23c682;
  background: #effbf6;
}

.option.wrong {
  border-color: #ff6b6b;
  background: #fff4f4;
}

.letter {
  width: 44rpx;
  height: 44rpx;
  margin-right: 18rpx;
  border: 2rpx solid #c9d2e3;
  border-radius: 50%;
  color: #5c667a;
  font-size: 24rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.option.selected .letter {
  border-color: #2f7bff;
  color: #2f7bff;
}

.option.correct .letter {
  border-color: #23c682;
  color: #23c682;
}

.option.wrong .letter {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.option-text {
  flex: 1;
  color: #263247;
  line-height: 1.6;
}

.submit-btn {
  height: 88rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 24rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.submit-btn::after,
.nav-btn::after {
  border: 0;
}

.answer-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.answer-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.answer-title.ok {
  color: #23b26b;
}

.answer-title.bad {
  color: #f04438;
}

.answer-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
  color: #6a7485;
}

.answer-code {
  color: #ff4d4f;
  font-weight: 800;
}

.analysis {
  margin-top: 18rpx;
  color: #5c667a;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eef1f6;
  background: rgba(255, 255, 255, 0.98);
  box-sizing: border-box;
}

.tool {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  width: 72rpx;
  color: #4b5568;
  font-size: 20rpx;
}

.tool-icon {
  width: 28rpx;
  height: 28rpx;
}

.nav-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.nav-btn.ghost {
  border: 1rpx solid #d9e1ef;
  background: #fff;
  color: #5c667a;
}
