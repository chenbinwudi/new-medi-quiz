.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 82rpx;
  padding: 0 24rpx;
  color: #9aa4b5;
  font-size: 28rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 34rpx 18rpx;
  margin: 36rpx 0 28rpx;
}

.category {
  text-align: center;
  font-size: 23rpx;
}

.category-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 14rpx;
  border-radius: 22rpx;
  box-shadow: 0 12rpx 22rpx rgba(47, 123, 255, 0.12);
}

.category-img {
  width: 54rpx;
  height: 54rpx;
}

.category-name {
  color: #263247;
  white-space: nowrap;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.material-row {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  padding: 22rpx;
}

.file-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 92rpx;
  margin-right: 20rpx;
  border-radius: 18rpx;
  background: #2f7bff;
}

.file-img {
  width: 56rpx;
  height: 56rpx;
}

.material-main {
  flex: 1;
  min-width: 0;
}

.material-title {
  color: #172033;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.material-meta,
.learner {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.learner {
  flex-shrink: 0;
  margin-left: 16rpx;
}
