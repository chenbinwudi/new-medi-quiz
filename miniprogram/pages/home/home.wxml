<view class="page page-safe home-page">
  <view class="top-bar">
    <view>
      <view class="page-title">医考通</view>
      <view class="page-subtitle">{{exam.fullName}}</view>
    </view>
    <view class="countdown">
      <text class="muted">距离考试</text>
      <text class="count-num">{{daysLeft}}</text>
      <text class="muted">天</text>
    </view>
  </view>

  <view class="search-row soft-card">
    <image class="icon-sm" src="/assets/icons/search.svg" mode="aspectFit" />
    <text>{{exam.name}}</text>
    <text class="search-arrow">⌄</text>
  </view>

  <view class="hero card">
    <view class="hero-copy">
      <view class="hero-title">2024 执业医师考试</view>
      <view class="hero-title blue">全程备考规划</view>
      <view class="hero-tag">科学备考 · 高效通关</view>
    </view>
    <view class="hero-doc">
      <image class="hero-icon" src="/assets/icons/outline.svg" mode="aspectFit" />
    </view>
  </view>

  <view class="shortcut-grid">
    <view wx:for="{{shortcuts}}" wx:key="label" class="shortcut" data-url="{{item.url}}" bindtap="go">
      <view class="shortcut-icon {{item.tone}}">
        <image class="shortcut-img" src="{{item.icon}}" mode="aspectFit" />
      </view>
      <view class="shortcut-label">{{item.label}}</view>
    </view>
  </view>

  <view class="section-card card">
    <view class="section-head">
      <text class="section-title">今日练习</text>
      <text class="section-more">继续练习 ›</text>
    </view>
    <view class="stats-row">
      <stat-card value="{{stats.questionCount}}" label="题目数" />
      <stat-card value="{{stats.doneCount}}" label="做题数" />
      <stat-card value="{{stats.accuracy}}" label="正确率" tone="primary" />
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">推荐资料</text>
      <text class="section-more">更多 ›</text>
    </view>
    <view class="material-list">
      <view wx:for="{{materials}}" wx:key="id" class="material-row soft-card" data-id="{{item.id}}" bindtap="goMaterial">
        <view class="file-icon">
          <image class="file-img" src="/assets/icons/outline.svg" mode="aspectFit" />
        </view>
        <view class="material-main">
          <view class="material-title">{{item.title}}</view>
          <view class="material-meta">{{item.type}} · {{item.size}}</view>
        </view>
        <view class="learner">{{item.learnerCount}}人已学</view>
      </view>
    </view>
  </view>
</view>
