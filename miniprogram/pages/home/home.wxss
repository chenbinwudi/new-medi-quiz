.home-page {
  padding-bottom: 32rpx;
}

.top-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.search-row,
.section-head,
.section-title,
.material-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.search-row {
  margin: 28rpx 0;
}

.search-pill {
  color: #172033;
  font-weight: 600;
}

.countdown text {
  color: #2f7bff;
  font-size: 34rpx;
  font-weight: 800;
}

.hero {
  display: flex;
  justify-content: space-between;
  min-height: 210rpx;
  padding: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #dceaff, #82adff);
}

.hero-title {
  font-size: 34rpx;
  font-weight: 800;
}

.hero-title.blue {
  color: #175de8;
}

.hero-tag {
  display: inline-block;
  margin-top: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 22rpx;
}

.hero-illus {
  width: 150rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #2f7bff;
  font-weight: 800;
  line-height: 180rpx;
  text-align: center;
  transform: rotate(8deg);
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 34rpx 20rpx;
  margin: 38rpx 0;
}

.shortcut {
  text-align: center;
  font-size: 23rpx;
}

.shortcut-icon {
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 14rpx;
  border-radius: 14rpx;
  color: #fff;
  font-size: 22rpx;
  line-height: 52rpx;
}

.section-card {
  padding: 28rpx;
}

.section-head {
  margin-bottom: 28rpx;
  font-weight: 700;
}

.stats-row {
  display: flex;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  color: #172033;
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.section-title {
  margin: 36rpx 4rpx 18rpx;
  font-weight: 800;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.material-row {
  min-height: 112rpx;
}

.file-icon {
  width: 72rpx;
  height: 82rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 22rpx;
  line-height: 82rpx;
  text-align: center;
}

.material-main {
  flex: 1;
}

.material-title {
  margin-bottom: 10rpx;
  font-weight: 700;
}
