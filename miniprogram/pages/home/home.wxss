.home-page {
  padding-bottom: 32rpx;
}

.countdown {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  font-size: 24rpx;
}

.count-num {
  color: #2f7bff;
  font-size: 36rpx;
  font-weight: 800;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 82rpx;
  padding: 0 24rpx;
  color: #172033;
  font-size: 28rpx;
  font-weight: 600;
}

.selector-icon {
  width: 30rpx;
  height: 30rpx;
  display: block;
}

.selector-text {
  flex: 1;
}

.search-arrow {
  color: #8a94a6;
  font-size: 28rpx;
}

.hero {
  position: relative;
  display: flex;
  justify-content: space-between;
  min-height: 214rpx;
  margin-top: 24rpx;
  padding: 32rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #e7f0ff 0%, #9fc1ff 100%);
}

.hero::after {
  position: absolute;
  right: -70rpx;
  top: -80rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.34);
  content: "";
}

.hero-copy {
  position: relative;
  z-index: 1;
}

.hero-title {
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.hero-title.blue {
  color: #175de8;
}

.hero-tag {
  display: inline-block;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #2f7bff;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.hero-doc {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 154rpx;
  height: 176rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 18rpx 30rpx rgba(47, 123, 255, 0.14);
  transform: rotate(8deg);
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 34rpx 18rpx;
  margin: 36rpx 0;
}

.shortcut {
  text-align: center;
  font-size: 23rpx;
}

.shortcut-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  margin: 0 auto 14rpx;
  border-radius: 22rpx;
  background: #eef5ff;
}

.shortcut-icon.green {
  background: #eaf9f0;
}

.shortcut-icon.orange {
  background: #fff1e8;
}

.shortcut-icon.purple {
  background: #f1edff;
}

.shortcut-icon.red {
  background: #fff0f0;
}

.shortcut-icon.amber {
  background: #fff7df;
}

.shortcut-icon.teal {
  background: #e8fbf7;
}

.shortcut-img {
  width: 46rpx;
  height: 46rpx;
}

.shortcut-label {
  color: #263247;
  white-space: nowrap;
}

.section-card {
  padding: 28rpx;
}

.stats-row {
  display: flex;
  gap: 14rpx;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.material-row {
  display: flex;
  align-items: center;
  min-height: 126rpx;
  padding: 22rpx;
}

.file-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 82rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  background: #2f7bff;
}

.file-img {
  width: 46rpx;
  height: 46rpx;
}

.material-main {
  flex: 1;
  min-width: 0;
}

.material-title {
  color: #172033;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.4;
}

.material-meta,
.learner {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 22rpx;
}

.learner {
  flex-shrink: 0;
  margin-left: 16rpx;
}
