.progress-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.progress-head,
.chapter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-num {
  margin-left: 14rpx;
  color: #23c682;
  font-size: 34rpx;
  font-weight: 800;
}

.progress-track,
.mini-track {
  border-radius: 999rpx;
  background: #edf1f7;
  overflow: hidden;
}

.progress-track {
  height: 14rpx;
  margin-top: 22rpx;
}

.progress-bar,
.mini-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f7bff, #23c682);
}

.chapter-list {
  margin-top: 24rpx;
  padding: 8rpx 24rpx;
}

.chapter-row {
  min-height: 104rpx;
  border-bottom: 1rpx solid #eef1f6;
}

.chapter-row:last-child {
  border-bottom: 0;
}

.chapter-plus {
  width: 32rpx;
  height: 32rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #2f7bff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.chapter-main {
  flex: 1;
  min-width: 0;
}

.chapter-name {
  color: #172033;
  font-weight: 700;
}

.mini-track {
  width: 220rpx;
  height: 8rpx;
  margin-top: 12rpx;
}

.chapter-side {
  width: 130rpx;
  text-align: right;
}

.chapter-count {
  color: #8a94a6;
  font-size: 22rpx;
}

.chapter-percent {
  margin-top: 6rpx;
  color: #23c682;
  font-size: 23rpx;
  font-weight: 700;
}

.paper-list,
.note-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 26rpx;
}

.paper-card {
  display: flex;
  align-items: center;
  min-height: 156rpx;
  padding: 24rpx;
}

.paper-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 82rpx;
  height: 82rpx;
  margin-right: 20rpx;
  border-radius: 22rpx;
  background: #eef5ff;
}

.paper-icon.green {
  background: #eaf9f0;
}

.paper-icon.orange {
  background: #fff1e8;
}

.paper-img {
  width: 48rpx;
  height: 48rpx;
}

.paper-main {
  flex: 1;
  min-width: 0;
}

.paper-title,
.note-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
}

.paper-desc,
.note-desc,
.paper-meta {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 23rpx;
  line-height: 1.5;
}

.paper-action {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2f7bff;
  font-size: 23rpx;
  font-weight: 700;
}

.note-card {
  padding: 26rpx;
}

.note-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.note-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2f7bff;
  font-size: 22rpx;
  font-weight: 700;
}

.note-icon {
  width: 44rpx;
  height: 44rpx;
}

.note-action {
  margin-top: 18rpx;
  color: #2f7bff;
  font-size: 24rpx;
  font-weight: 700;
}
