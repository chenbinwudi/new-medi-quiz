.progress-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.progress-head,
.chapter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-num {
  margin-left: 14rpx;
  color: #23c682;
  font-size: 34rpx;
  font-weight: 800;
}

.progress-track,
.mini-track {
  border-radius: 999rpx;
  background: #edf1f7;
  overflow: hidden;
}

.progress-track {
  height: 14rpx;
  margin-top: 22rpx;
}

.progress-bar,
.mini-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f7bff, #23c682);
}

.chapter-list {
  margin-top: 24rpx;
  padding: 8rpx 24rpx;
}

.chapter-row {
  min-height: 104rpx;
  border-bottom: 1rpx solid #eef1f6;
}

.chapter-row:last-child {
  border-bottom: 0;
}

.chapter-plus {
  width: 32rpx;
  height: 32rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #2f7bff;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.chapter-main {
  flex: 1;
  min-width: 0;
}

.chapter-name {
  color: #172033;
  font-weight: 700;
}

.mini-track {
  width: 220rpx;
  height: 8rpx;
  margin-top: 12rpx;
}

.chapter-side {
  width: 130rpx;
  text-align: right;
}

.chapter-count {
  color: #8a94a6;
  font-size: 22rpx;
}

.chapter-percent {
  margin-top: 6rpx;
  color: #23c682;
  font-size: 23rpx;
  font-weight: 700;
}
