.page-title {
  margin: 12rpx 0 28rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.subject-row,
.progress-head,
.chapter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.subject-row {
  margin-bottom: 20rpx;
  font-weight: 700;
}

.progress-card {
  margin-top: 28rpx;
  padding: 28rpx;
}

.green {
  color: #28c76f;
  font-weight: 800;
}

.progress-track {
  height: 12rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  background: #edf1f7;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: #35c987;
}

.chapter-list {
  margin-top: 20rpx;
}

.chapter-row {
  min-height: 82rpx;
  border-bottom: 1rpx solid #eef1f6;
}

.plus {
  width: 28rpx;
  height: 28rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #2f7bff;
  color: #fff;
  font-size: 22rpx;
  line-height: 28rpx;
  text-align: center;
}

.chapter-name {
  flex: 1;
  font-weight: 600;
}

.chapter-percent {
  width: 78rpx;
  color: #28c76f;
  text-align: right;
}
