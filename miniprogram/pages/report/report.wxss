.centered {
  justify-content: center;
}

.block {
  margin-top: 28rpx;
  padding: 28rpx;
}

.block-title {
  margin-bottom: 24rpx;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.trend {
  display: flex;
  height: 244rpx;
  align-items: flex-end;
  justify-content: space-between;
  border-bottom: 1rpx solid #eef1f6;
}

.trend-item {
  position: relative;
  flex: 1;
  height: 206rpx;
  text-align: center;
}

.trend-line {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(47, 123, 255, 0.32), rgba(47, 123, 255, 0));
  transform: translateX(-50%);
}

.dot {
  position: absolute;
  left: 50%;
  width: 14rpx;
  height: 14rpx;
  border: 4rpx solid #dbeafe;
  border-radius: 50%;
  background: #2f7bff;
  transform: translateX(-50%);
}

.rate {
  position: absolute;
  left: 0;
  right: 0;
  top: 4rpx;
  color: #5c667a;
  font-size: 22rpx;
}

.date {
  position: absolute;
  left: 0;
  right: 0;
  bottom: -34rpx;
  color: #8a94a6;
  font-size: 20rpx;
}

.stats-row {
  display: flex;
  gap: 14rpx;
}

.dist-wrap,
.legend-row,
.legend-left {
  display: flex;
  align-items: center;
}

.donut {
  position: relative;
  width: 170rpx;
  height: 170rpx;
  margin-right: 42rpx;
  border-radius: 50%;
  background: conic-gradient(#35c6c8 0 60%, #ffa629 60% 90%, #2f7bff 90% 100%);
}

.donut-hole {
  position: absolute;
  top: 42rpx;
  left: 42rpx;
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: #fff;
}

.legend {
  flex: 1;
}

.legend-row {
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #4b5568;
  font-size: 24rpx;
}

.legend-left {
  gap: 12rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
